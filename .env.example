# Required — powers all AI features (extraction, search, insights, follow-up).
ANTHROPIC_API_KEY=sk-ant-...

# Optional — enables semantic (hybrid) search. With it set, build the vector
# index from the Search page. Without it, Search falls back to keyword-only.
OPENAI_API_KEY=sk-...

# Optional — sets the DEFAULT Claude model. You can also switch models anytime
# from the sidebar picker inside the app.
# CAREER_CRM_MODEL=claude-opus-4-8
